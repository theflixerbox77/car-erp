generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionPlan {
  trial
  starter
  professional
  enterprise
  enterprise_plus

  @@map("subscription_plan")
}

enum SubscriptionStatus {
  pending_approval
  active
  suspended
  cancelled

  @@map("subscription_status")
}

enum UserStatus {
  active
  invited
  suspended

  @@map("user_status")
}

model Tenant {
  id                  String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug                String             @unique
  businessName        String             @map("business_name")
  legalName           String?            @map("legal_name")
  logoUrl             String?            @map("logo_url")
  address             String?
  city                String?
  country             String?
  phone               String?
  whatsappNumber      String?            @map("whatsapp_number")
  subscriptionPlan    String             @default("trial") @map("subscription_plan")
  subscriptionStatus  String             @default("pending_approval") @map("subscription_status")
  approvedBy          String?            @map("approved_by") @db.Uuid
  approvedAt          DateTime?          @map("approved_at")
  storefrontSettings  Json               @default("{}") @map("storefront_settings")
  customDomain        String?            @map("custom_domain")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @default(now()) @map("updated_at")

  roles               Role[]
  users               User[]             @relation("TenantUsers")
  approvedByUser      User?              @relation("TenantApprovedBy", fields: [approvedBy], references: [id])
  auditLogs           AuditLog[]
  vehicles            Vehicle[]
  vehicleMedia        VehicleMedia[]
  vehicleStatusHistory VehicleStatusHistory[]
  customers                  Customer[]
  customerInterestedVehicles CustomerInterestedVehicle[]
  customerInteractions       CustomerInteraction[]
  leads                      Lead[]
  leadStageHistory           LeadStageHistory[]
  sales                      Sale[]
  salePayments               SalePayment[]
  saleDocuments               SaleDocument[]
  expenseCategories           ExpenseCategory[]
  expenses                    Expense[]
  recurringExpenseSchedules   RecurringExpenseSchedule[]
  employees                   Employee[]
  attendance                  Attendance[]
  leaveRequests                LeaveRequest[]
  employeePerformance         EmployeePerformance[]
  reminders                   Reminder[]
  notifications                Notification[]

  @@map("tenants")
}

model Role {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String?          @map("tenant_id") @db.Uuid
  name       String
  isSystem   Boolean          @default(false) @map("is_system")
  createdAt  DateTime         @default(now()) @map("created_at")

  tenant           Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users            User[]
  rolePermissions  RolePermission[]
  employees        Employee[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model User {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String?    @map("tenant_id") @db.Uuid
  email           String
  passwordHash    String     @map("password_hash")
  fullName        String     @map("full_name")
  phone           String?
  avatarUrl       String?    @map("avatar_url")
  roleId          String?    @map("role_id") @db.Uuid
  isPlatformAdmin Boolean    @default(false) @map("is_platform_admin")
  status          String     @default("active")
  lastLoginAt     DateTime?  @map("last_login_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @default(now()) @map("updated_at")

  tenant              Tenant?     @relation("TenantUsers", fields: [tenantId], references: [id], onDelete: Cascade)
  role                Role?       @relation(fields: [roleId], references: [id])
  approvedTenants     Tenant[]    @relation("TenantApprovedBy")
  auditLogs           AuditLog[]

  @@unique([email])
  @@index([tenantId])
  @@map("users")
}

model Permission {
  id     String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code   String @unique
  module String

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String?  @map("tenant_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id") @db.Uuid
  beforeData Json?    @map("before_data")
  afterData  Json?    @map("after_data")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Vehicle {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  stockNumber         String    @map("stock_number")
  vin                 String?
  chassisNumber       String?   @map("chassis_number")
  engineNumber        String?   @map("engine_number")
  brand               String
  model               String
  trim                String?
  year                Int
  auctionGrade        String?   @map("auction_grade")
  registrationNumber  String?   @map("registration_number")
  registrationExpiry  DateTime? @map("registration_expiry") @db.Date
  fuelType            String?   @map("fuel_type")
  transmission        String?
  driveType           String?   @map("drive_type")
  mileage             Int?
  color               String?
  condition           String?
  bodyType            String?   @map("body_type")
  features            Json      @default("[]")

  importCost         Decimal @default(0) @map("import_cost") @db.Decimal(14, 2)
  auctionCost        Decimal @default(0) @map("auction_cost") @db.Decimal(14, 2)
  shippingCost       Decimal @default(0) @map("shipping_cost") @db.Decimal(14, 2)
  customsCost        Decimal @default(0) @map("customs_cost") @db.Decimal(14, 2)
  repairCost         Decimal @default(0) @map("repair_cost") @db.Decimal(14, 2)
  registrationCost   Decimal @default(0) @map("registration_cost") @db.Decimal(14, 2)
  totalCost          Decimal @default(0) @map("total_cost") @db.Decimal(14, 2)
  sellingPrice       Decimal? @map("selling_price") @db.Decimal(14, 2)
  expectedProfit     Decimal? @map("expected_profit") @db.Decimal(14, 2)
  minimumPrice       Decimal? @map("minimum_price") @db.Decimal(14, 2)
  discountAmount     Decimal @default(0) @map("discount_amount") @db.Decimal(14, 2)

  status     String   @default("available")
  isFeatured Boolean  @default(false) @map("is_featured")
  soldAt     DateTime? @map("sold_at")

  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  media         VehicleMedia[]
  statusHistory VehicleStatusHistory[]
  interestedBy  CustomerInterestedVehicle[]
  leads         Lead[]
  sales         Sale[]
  expenses      Expense[]

  @@unique([tenantId, stockNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, brand, model])
  @@map("vehicles")
}

model VehicleMedia {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId    String   @map("vehicle_id") @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  type         String
  url          String
  storagePath  String   @map("storage_path")
  thumbnailUrl String?  @map("thumbnail_url")
  sortOrder    Int      @default(0) @map("sort_order")
  isPrimary    Boolean  @default(false) @map("is_primary")
  uploadedBy   String?  @map("uploaded_by") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([tenantId])
  @@map("vehicle_media")
}

model VehicleStatusHistory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId  String   @map("vehicle_id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  changedBy  String?  @map("changed_by") @db.Uuid
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([tenantId])
  @@map("vehicle_status_history")
}

model Customer {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  fullName              String    @map("full_name")
  phone                 String?
  email                 String?
  address               String?
  nidNumber             String?   @map("nid_number")
  licenseNumber         String?   @map("license_number")
  notes                 String?
  source                String?
  assignedSalespersonId String?   @map("assigned_salesperson_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @map("updated_at")

  tenant       Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  interests    CustomerInterestedVehicle[]
  interactions CustomerInteraction[]
  leads        Lead[]
  sales        Sale[]

  @@index([tenantId])
  @@map("customers")
}

model CustomerInterestedVehicle {
  customerId String   @map("customer_id") @db.Uuid
  vehicleId  String   @map("vehicle_id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle  Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([customerId, vehicleId])
  @@index([tenantId])
  @@map("customer_interested_vehicles")
}

model CustomerInteraction {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  type       String
  summary    String
  occurredAt DateTime @default(now()) @map("occurred_at")
  createdBy  String?  @map("created_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([tenantId])
  @@map("customer_interactions")
}

model Lead {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  customerId        String    @map("customer_id") @db.Uuid
  vehicleId         String?   @map("vehicle_id") @db.Uuid
  source            String?
  stage             String    @default("new")
  assignedTo        String?   @map("assigned_to") @db.Uuid
  expectedCloseDate DateTime? @map("expected_close_date") @db.Date
  lostReason        String?   @map("lost_reason")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @map("updated_at")

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer     Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  vehicle      Vehicle?           @relation(fields: [vehicleId], references: [id])
  stageHistory LeadStageHistory[]
  sales        Sale[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@map("leads")
}

model LeadStageHistory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId     String   @map("lead_id") @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  fromStage  String?  @map("from_stage")
  toStage    String   @map("to_stage")
  changedBy  String?  @map("changed_by") @db.Uuid
  note       String?
  createdAt  DateTime @default(now()) @map("created_at")

  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([tenantId])
  @@map("lead_stage_history")
}

model Sale {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  leadId          String?   @map("lead_id") @db.Uuid
  customerId      String    @map("customer_id") @db.Uuid
  vehicleId       String    @map("vehicle_id") @db.Uuid
  salespersonId   String?   @map("salesperson_id") @db.Uuid
  salePrice       Decimal   @map("sale_price") @db.Decimal(14, 2)
  discount        Decimal   @default(0) @db.Decimal(14, 2)
  commissionRate  Decimal   @default(0) @map("commission_rate") @db.Decimal(5, 2)
  commissionAmount Decimal  @default(0) @map("commission_amount") @db.Decimal(14, 2)
  profit          Decimal   @default(0) @db.Decimal(14, 2)
  paymentStatus   String    @default("pending") @map("payment_status")
  deliveryDate    DateTime? @map("delivery_date") @db.Date
  warrantyMonths  Int?      @map("warranty_months")
  warrantyNotes   String?   @map("warranty_notes")
  status          String    @default("active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @map("updated_at")

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead      Lead?          @relation(fields: [leadId], references: [id])
  customer  Customer       @relation(fields: [customerId], references: [id])
  vehicle   Vehicle        @relation(fields: [vehicleId], references: [id])
  payments  SalePayment[]
  documents SaleDocument[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("sales")
}

model SalePayment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId        String   @map("sale_id") @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  amount        Decimal  @db.Decimal(14, 2)
  method        String
  paidAt        DateTime @default(now()) @map("paid_at")
  referenceNote String?  @map("reference_note")
  recordedBy    String?  @map("recorded_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([tenantId])
  @@map("sale_payments")
}

model SaleDocument {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  saleId      String   @map("sale_id") @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  type        String
  storagePath String   @map("storage_path")
  version     Int      @default(1)
  generatedBy String?  @map("generated_by") @db.Uuid
  generatedAt DateTime @default(now()) @map("generated_at")

  sale   Sale   @relation(fields: [saleId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([tenantId])
  @@map("sale_documents")
}

model ExpenseCategory {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  name                String
  isRecurringDefault  Boolean  @default(false) @map("is_recurring_default")
  createdAt           DateTime @default(now()) @map("created_at")

  tenant                   Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expenses                 Expense[]
  recurringExpenseSchedules RecurringExpenseSchedule[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("expense_categories")
}

model Expense {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  categoryId          String    @map("category_id") @db.Uuid
  vehicleId           String?   @map("vehicle_id") @db.Uuid
  amount              Decimal   @db.Decimal(14, 2)
  description         String?
  receiptUrl          String?   @map("receipt_url")
  receiptStoragePath  String?   @map("receipt_storage_path")
  expenseDate         DateTime  @default(now()) @map("expense_date") @db.Date
  isRecurring         Boolean   @default(false) @map("is_recurring")
  status              String    @default("pending")
  submittedBy         String?   @map("submitted_by") @db.Uuid
  approvedBy          String?   @map("approved_by") @db.Uuid
  approvedAt          DateTime? @map("approved_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @map("updated_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  vehicle  Vehicle?        @relation(fields: [vehicleId], references: [id])

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("expenses")
}

model RecurringExpenseSchedule {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  categoryId   String   @map("category_id") @db.Uuid
  amount       Decimal  @db.Decimal(14, 2)
  description  String?
  frequency    String
  nextRunDate  DateTime @map("next_run_date") @db.Date
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant   Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category ExpenseCategory @relation(fields: [categoryId], references: [id])

  @@index([tenantId])
  @@map("recurring_expense_schedules")
}

model Employee {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  userId           String?   @map("user_id") @db.Uuid
  fullName         String    @map("full_name")
  phone            String?
  email            String?
  roleId           String?   @map("role_id") @db.Uuid
  employmentStatus String    @default("active") @map("employment_status")
  hireDate         DateTime? @map("hire_date") @db.Date
  salaryAmount     Decimal?  @map("salary_amount") @db.Decimal(14, 2)
  salaryType       String?   @map("salary_type")
  commissionRate   Decimal?  @map("commission_rate") @db.Decimal(5, 2)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @map("updated_at")

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         Role?                @relation(fields: [roleId], references: [id])
  attendance   Attendance[]
  leaveRequests LeaveRequest[]
  performance  EmployeePerformance[]

  @@index([tenantId])
  @@map("employees")
}

model Attendance {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  employeeId    String    @map("employee_id") @db.Uuid
  date          DateTime  @db.Date
  checkInTime   DateTime? @map("check_in_time")
  checkOutTime  DateTime? @map("check_out_time")
  status        String    @default("present")
  note          String?
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([tenantId])
  @@map("attendance")
}

model LeaveRequest {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  employeeId String   @map("employee_id") @db.Uuid
  type       String   @default("other")
  startDate  DateTime @map("start_date") @db.Date
  endDate    DateTime @map("end_date") @db.Date
  status     String   @default("pending")
  approvedBy String?  @map("approved_by") @db.Uuid
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("leave_requests")
}

model EmployeePerformance {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  employeeId  String   @map("employee_id") @db.Uuid
  periodStart DateTime @map("period_start") @db.Date
  periodEnd   DateTime @map("period_end") @db.Date
  metrics     Json     @default("{}")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("employee_performance")
}

model Reminder {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  type               String
  relatedCustomerId  String?   @map("related_customer_id") @db.Uuid
  relatedSaleId      String?   @map("related_sale_id") @db.Uuid
  relatedVehicleId   String?   @map("related_vehicle_id") @db.Uuid
  dueAt              DateTime  @map("due_at")
  status             String    @default("pending")
  assignedTo         String?   @map("assigned_to") @db.Uuid
  note               String?
  createdAt          DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status, dueAt])
  @@map("reminders")
}

model Notification {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  userId             String?  @map("user_id") @db.Uuid
  title              String
  body               String?
  type               String   @default("general")
  relatedEntityType  String?  @map("related_entity_type")
  relatedEntityId    String?  @map("related_entity_id") @db.Uuid
  isRead             Boolean  @default(false) @map("is_read")
  createdAt          DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId, isRead])
  @@map("notifications")
}
